@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card sky-card border-0">
                <div class="card-header sky-header text-center py-4">
                    <h2 class="mb-0"><i class="fa-solid fa-plane-departure me-2"></i>SkyWings</h2>
                    <p class="small mb-0 opacity-75">Welcome back, Traveler</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">
                        <h4 class="text-center mb-4 fw-bold" style="color: var(--dark-blue);">Account Login</h4>
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-0 bg-light" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted">Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-0 bg-light" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label small text-muted" asp-for="Input.RememberMe">
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>
                         

                        <div>
                            <button id="login-submit" type="submit" class="w-100 btn btn-sky btn-lg py-3 fw-bold">Sign In</button>
                        </div>

                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <div class="text-center my-4">
                                    <span class="text-muted small px-2 bg-white" style="position:relative; z-index:1;">Or continue with</span>
                                    <hr style="margin-top:-10px;">
                                </div>
                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                    <div class="d-grid gap-2">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                                @if (provider.DisplayName == "Google")
                                                {
                                                    <i class="fa-brands fa-google me-2"></i>
                                                }
                                                @provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }
                    </form>
                </div>

                <div class="card-footer bg-light border-0 text-center py-3">
                    <p class="mb-0 small text-muted">
                        Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none text-primary">Register Now</a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 