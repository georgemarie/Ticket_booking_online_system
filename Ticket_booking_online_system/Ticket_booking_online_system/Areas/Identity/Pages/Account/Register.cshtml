@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card sky-card border-0">
                <div class="card-header sky-header text-center py-4">
                    <h2 class="mb-0"><i class="fa-solid fa-plane-departure me-2"></i>SkyWings</h2>
                    <p class="small mb-0 opacity-75">Start your journey with us</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <h4 class="text-center mb-4 fw-bold" style="color: var(--dark-blue);">Create Account</h4>

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-0 bg-light" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted">Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Name" class="form-control border-0 bg-light" placeholder="Full Name" />
                                    <label asp-for="Input.Name" class="text-muted">Full Name</label>
                                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Passport_num" class="form-control border-0 bg-light" placeholder="Passport No." />
                                    <label asp-for="Input.Passport_num" class="text-muted">Passport No.</label>
                                    <span asp-validation-for="Input.Passport_num" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-0 bg-light" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-light" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="w-100 btn btn-sky btn-lg py-3 fw-bold mb-3">Register Now</button>

                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <div class="text-center my-3">
                                    <hr class="text-muted">
                                    <p class="small text-muted mb-3">Or sign up with</p>
                                </div>
                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                    <div class="d-grid">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name">
                                                @if (provider.DisplayName == "Google")
                                                {
                                                    <i class="fa-brands fa-google me-2"></i>
                                                }
                                                @provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }
                    </form>
                </div>

                <div class="card-footer bg-light border-0 text-center py-3">
                    <p class="mb-0 small text-muted">
                        Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none text-primary">Log In</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}