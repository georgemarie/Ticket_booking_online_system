@model DAL.Models.FlightService
@{
    ViewData["Title"] = "Edit Flight";
}

<h1>Edit Flight Service</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ServiceId" />

            <div class="form-group mb-3">
                <label asp-for="Flight_Number" class="control-label">Flight Number</label>
                <select asp-for="Flight_Number" class="form-control" asp-items="ViewBag.Flights">
                    <option value="">-- Select Flight --</option>
                </select>
                <span asp-validation-for="Flight_Number" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}