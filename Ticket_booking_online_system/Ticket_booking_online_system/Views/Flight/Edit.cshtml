@using DAL.Models
@model DAL.Models.FlightService

@{
    ViewData["Title"] = "Edit Flight";
}

<h1>Edit Flight</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        @* FIXED: Separated method from validation and closed the opening tag correctly *@
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- Keys -->
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ServiceId" />

            <!-- IMPORTANT: keep both in sync -->
            <input type="hidden" asp-for="Flight_Number" />
            <input type="hidden" asp-for="Flight.Flight_Number" />

            <!-- Flight Details -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">Flight Details</div>
                <div class="card-body">

                    <!-- Show flight number but keep it readonly + bindable -->
                    <div class="form-group mb-2">
                        <label asp-for="Flight.Flight_Number" class="control-label">Flight Number</label>
                        <input asp-for="Flight.Flight_Number" class="form-control" readonly />
                        <span asp-validation-for="Flight.Flight_Number" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label>Origin City</label>
                                <select asp-for="Flight.Origin_LocationID" class="form-control" asp-items="ViewBag.Locations">
                                    <option value="0">-- Select Origin --</option>
                                </select>
                                <span asp-validation-for="Flight.Origin_LocationID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label>Destination City</label>
                                <select asp-for="Flight.Dest_LocationID" class="form-control" asp-items="ViewBag.Locations">
                                    <option value="0">-- Select Destination --</option>
                                </select>
                                <span asp-validation-for="Flight.Dest_LocationID" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label asp-for="Flight.Depart_Date" class="control-label"></label>
                                <input asp-for="Flight.Depart_Date" type="datetime-local" class="form-control" />
                                <span asp-validation-for="Flight.Depart_Date" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label asp-for="Flight.Arrival_Time" class="control-label"></label>
                                <input asp-for="Flight.Arrival_Time" type="datetime-local" class="form-control" />
                                <span asp-validation-for="Flight.Arrival_Time" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label>Airline</label>
                                <select asp-for="Flight.Airline_ID" class="form-control" asp-items="ViewBag.Airlines">
                                    <option value="0">-- Select Airline --</option>
                                </select>
                                <span asp-validation-for="Flight.Airline_ID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label asp-for="Flight.Available_Seats" class="control-label"></label>
                                <input asp-for="Flight.Available_Seats" type="number" class="form-control" />
                                <span asp-validation-for="Flight.Available_Seats" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-2">
                        <label asp-for="Flight.Class" class="control-label"></label>
                        <select asp-for="Flight.Class" class="form-control"
                                asp-items="@Html.GetEnumSelectList<FlightClass>()">
                        </select>
                        <span asp-validation-for="Flight.Class" class="text-danger"></span>
                    </div>

                </div>
            </div>

            <!-- Service / Pricing -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">Service / Pricing</div>
                <div class="card-body">
                    <div class="form-group mb-2">
                        <label asp-for="Service.BasePrice" class="control-label">Ticket Price</label>
                        <input asp-for="Service.BasePrice" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Service.BasePrice" class="text-danger"></span>
                    </div>

                    <input type="hidden" asp-for="Service.ServiceType" value="Flight" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            @* FIXED: Corrected the broken Back to List link and tag *@
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}