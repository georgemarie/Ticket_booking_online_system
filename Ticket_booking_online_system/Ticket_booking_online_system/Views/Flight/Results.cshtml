@model DAL.ViewModels.FlightSearchVM

<h2>Flights</h2>

@foreach (var item in Model.Flights)
{
    <div style="border:1px solid gray; margin:10px; padding:10px;">

        <h3>@item.Flight.Flight_Number</h3>

        <p>
            @item.Flight.OriginLocation.City →
            @item.Flight.DestLocation.City
        </p>

        <form asp-controller="Booking"
              asp-action="CreateBooking"
              method="post">

            <input type="hidden"
                   name="serviceId"
                   value="@item.ServiceId" />

            <button>Book</button>

        </form>

    </div>
}