@using DAL.Models
@model DAL.Models.FlightService

@{
    ViewData["Title"] = "Add Flight Service";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 style="color: var(--dark-blue);">Create New Flight</h2>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="card sky-card mb-4">
                    <div class="card-header sky-header py-3">
                        <h5 class="mb-0"><i class="fa-solid fa-plane-departure me-2"></i>Flight Logistics</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Flight.Flight_Number" class="form-label fw-bold">Flight Number</label>
                                <input asp-for="Flight.Flight_Number" class="form-control" placeholder="e.g. MS737" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Flight.Airline_ID" class="form-label fw-bold">Airline</label>
                                <select asp-for="Flight.Airline_ID" class="form-select" asp-items="ViewBag.Airlines">
                                    <option value="">-- Select Airline --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Origin City</label>
                                <select asp-for="Flight.Origin_LocationID" class="form-select" asp-items="ViewBag.Locations">
                                    <option value="0">-- Select Origin --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Destination City</label>
                                <select asp-for="Flight.Dest_LocationID" class="form-select" asp-items="ViewBag.Locations">
                                    <option value="0">-- Select Destination --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Flight.Depart_Date" class="form-label fw-bold">Departure Time</label>
                                <input asp-for="Flight.Depart_Date" type="datetime-local" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Flight.Arrival_Time" class="form-label fw-bold">Arrival Time</label>
                                <input asp-for="Flight.Arrival_Time" type="datetime-local" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card sky-card mb-4 border-info border-top border-4">
                    <div class="card-body p-4">
                        <h5 class="mb-3 text-info"><i class="fa-solid fa-tags me-2"></i>Pricing & Capacity</h5>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Flight.Available_Seats" class="form-label fw-bold">Total Seats</label>
                                <input asp-for="Flight.Available_Seats" class="form-control" type="number" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Flight.Class" class="form-label fw-bold">Class</label>
                                <select asp-for="Flight.Class" class="form-select" asp-items="@Html.GetEnumSelectList<DAL.Models.FlightClass>()"></select>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Service.BasePrice" class="form-label fw-bold">Ticket Price ($)</label>
                                <input asp-for="Service.BasePrice" class="form-control text-success fw-bold" type="number" step="0.01" />
                            </div>
                        </div>
                        <input type="hidden" asp-for="Service.ServiceType" value="Flight" />
                    </div>
                </div>

                <div class="text-end mb-5">
                    <button type="submit" class="btn btn-sky btn-lg px-5">Save Flight</button>
                </div>
            </form>
        </div>
    </div>
</div>