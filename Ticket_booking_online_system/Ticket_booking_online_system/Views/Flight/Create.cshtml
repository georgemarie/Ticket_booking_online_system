@using DAL.Models
@model DAL.Models.FlightService

@{
    ViewData["Title"] = "Add Flight Service";
}

<h1>Add New Flight</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="card mb-3">
                <div class="card-header bg-primary text-white">Flight Details</div>
                <div class="card-body">
                    <div class="form-group mb-2">
                        <label asp-for="Flight.Flight_Number" class="control-label"></label>
                        <input asp-for="Flight.Flight_Number" class="form-control" placeholder="e.g. MS737" />
                        <span asp-validation-for="Flight.Flight_Number" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label asp-for="Flight.Origin_LocationID" class="control-label">Origin</label>
                                <select asp-for="Flight.Origin_LocationID" class="form-control" asp-items="@Html.GetEnumSelectList<DAL.Models.Country>()"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-2">
                                <label asp-for="Flight.Dest_LocationID" class="control-label">Destination</label>
                                <select asp-for="Flight.Dest_LocationID" class="form-control" asp-items="@Html.GetEnumSelectList<DAL.Models.Country>()"></select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-2">
                        <label asp-for="Flight.Depart_Date" class="control-label"></label>
                        <input asp-for="Flight.Depart_Date" type="datetime-local" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-success text-white">Pricing & Service Info</div>
                <div class="card-body">
                    <div class="form-group mb-2">
                        <label asp-for="Service.BasePrice" class="control-label">Ticket Price</label>
                        <input asp-for="Service.BasePrice" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Service.BasePrice" class="text-danger"></span>
                    </div>
                    @* Set the ServiceType automatically *@
                    <input type="hidden" asp-for="Service.ServiceType" value="Flight" />
                </div>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Flight" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>