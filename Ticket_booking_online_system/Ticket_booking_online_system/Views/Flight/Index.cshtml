@model IEnumerable<DAL.Models.FlightService>

@{
    ViewData["Title"] = "Manage Flights";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--dark-blue);"><i class="fa-solid fa-plane-circle-check me-2"></i>Flight Management</h2>
        <a asp-action="Create" class="btn btn-sky"><i class="fa-solid fa-plus me-1"></i> Add New Flight</a>
    </div>

    <div class="card sky-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted">
                        <tr>
                            <th class="ps-4">Flight No</th>
                            <th>Airline</th>
                            <th>Route</th>
                            <th>Departure / Arrival</th>
                            <th>Class / Seats</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.Flight?.Flight_Number</td>
                                <td><span class="badge bg-secondary">@item.Flight?.Airline?.Airline_Name</span></td>
                                <td>
                                    @item.Flight?.OriginLocation?.City <i class="fa-solid fa-arrow-right text-muted mx-1"></i> @item.Flight?.DestLocation?.City
                                </td>
                                <td>
                                    <div><small class="text-muted">Dep:</small> @(item.Flight?.Depart_Date.ToString("MMM dd, HH:mm") ?? "N/A")</div>
                                    <div><small class="text-muted">Arr:</small> @(item.Flight?.Arrival_Time?.ToString("MMM dd, HH:mm") ?? "N/A")</div>
                                </td>
                                <td>
                                    <div>@item.Flight?.Class</div>
                                    <div class="text-success small fw-bold">@item.Flight?.Available_Seats seats left</div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="View"><i class="fa-solid fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fa-solid fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>