@model IEnumerable<DAL.Models.FlightService>
@{
    ViewData["Title"] = "Flights";
}

<h1>Available Flights</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Add New Flight</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Flight Number</th>
            <th>Origin</th>
            <th>Destination</th>
            <th>Departure</th>
            <th>Arrival</th>
            <th>Class</th>
            <th>Available Seats</th>
            <th>Airline</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Flight?.Flight_Number</td>
                <td>@item.Flight?.OriginLocation?.City</td>
                <td>@item.Flight?.DestLocation?.City</td>
                <td>@item.Flight?.Depart_Date.ToShortDateString()</td>
                <td>@item.Flight?.Arrival_Time.ToShortTimeString()</td>
                <td>@item.Flight?.Class</td>
                <td>@item.Flight?.Available_Seats</td>
                <td>@item.Flight?.Airline?.Airline_Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>