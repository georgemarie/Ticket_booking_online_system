@model IEnumerable<DAL.Models.FlightService>

@{
    ViewData["Title"] = "Flight Results";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--dark-blue);">Available Flights</h2>
        <a asp-action="Index" asp-route-type="Flight" class="btn btn-outline-secondary">Modify Search</a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card sky-card flex-row align-items-center p-3">
                    <div class="p-3 text-center border-end" style="width: 150px;">
                        <i class="fa-solid fa-plane-tail fa-2x text-primary mb-2"></i>
                        <h6 class="fw-bold mb-0">@item.Flight?.Airline?.Airline_Name</h6>
                        <small class="text-muted">@item.Flight?.Flight_Number</small>
                    </div>

                    <div class="p-4 flex-grow-1 d-flex justify-content-between align-items-center">
                        <div class="text-center">
                            <h4 class="fw-bold mb-0">@(item.Flight?.Depart_Date.ToString("HH:mm") ?? "--:--")</h4>
                            <p class="text-muted mb-0">@item.Flight?.OriginLocation?.City</p>
                        </div>
                        
                        <div class="flex-grow-1 px-4 text-center">
                            <small class="text-muted">Direct</small>
                            <hr class="my-1 border-primary opacity-50" style="border-top: 2px dashed;" />
                            <i class="fa-solid fa-plane text-primary"></i>
                        </div>

                        <div class="text-center">
                            <h4 class="fw-bold mb-0">@(item.Flight?.Arrival_Time?.ToString("HH:mm") ?? "--:--")</h4>
                            <p class="text-muted mb-0">@item.Flight?.DestLocation?.City</p>
                        </div>
                    </div>

                    <div class="p-4 border-start text-center bg-light rounded-end" style="width: 200px;">
                        <h3 class="text-success fw-bold mb-1">@(item.Service?.BasePrice.ToString("C") ?? "0.00")</h3>
                        <p class="small text-muted mb-3">@item.Flight?.Class Class</p>
                        
                        @if (User.IsInRole("User"))
                        {
                            <a asp-controller="Booking" asp-action="Create" asp-route-serviceId="@item.ServiceId" class="btn btn-sky w-100">Book Now</a>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <span class="badge bg-warning text-dark p-2">Admin View</span>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary w-100">Login to Book</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>