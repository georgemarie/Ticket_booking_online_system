@model IEnumerable<DAL.Models.HotelService>

@{
    ViewData["Title"] = "Hotel Search Results";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Hotels in Selected City</h2>
        <a asp-action="Index" class="btn btn-secondary">Back to Search</a>
    </div>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="thead-dark bg-dark text-white">
            <tr>
                <th>Hotel Name</th>
                <th>Room Type</th>
                <th>City</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Price per Night</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                <tr>
                    <td>
                        <strong>@Html.DisplayFor(modelItem => item.Hotel_Name)</strong>
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Room_Type)
                    </td>
                    <td>
                        @* Accessing Location through the Service navigation *@
                        @item.Service?.Location?.City
                    </td>
                    <td>
                        @* Check if has value, then call .Value.ToShortDateString() *@
                        @(item.Check_In.HasValue ? item.Check_In.Value.ToShortDateString() : "N/A")
                    </td>
                    <td>
                        @(item.Check_Out.HasValue ? item.Check_Out.Value.ToShortDateString() : "N/A")
                    </td>
                    <td>
                        @* Accessing Price from the parent Service table *@
                        <span class="text-success fw-bold">
                            @Html.DisplayFor(modelItem => item.Service.BasePrice)
                        </span>
                    </td>
                    <td>
                        <a asp-controller="Hotel" asp-action="Details" asp-route-serviceId="@item.ServiceId" class="btn btn-sm btn-primary">Book Room</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>