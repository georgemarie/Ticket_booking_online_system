@model DAL.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<h1>Booking Details</h1>
<hr />

<dl class="row">
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">User</dt>
    <dd class="col-sm-9">@Model.User?.Email</dd>

    <dt class="col-sm-3">Service</dt>
    <dd class="col-sm-9">@Model.Service?.ServiceType</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.BookingID" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>