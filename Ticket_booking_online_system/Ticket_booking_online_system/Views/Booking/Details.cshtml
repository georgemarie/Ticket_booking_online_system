@model DAL.Models.Booking

@{
    ViewData["Title"] = "Your Ticket";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card sky-card" style="border: 1px solid #e2e8f0;">
                
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="mb-0" style="color: var(--dark-blue); font-weight: 800;">SkyWings</h2>
                    <span class="badge bg-success fs-6 px-3 py-2 rounded-pill">@Model.Status</span>
                </div>
                
                <div class="card-body p-4">
                    <div class="text-center mb-4 pb-3 border-bottom">
                        <h5 class="text-muted text-uppercase tracking-wide mb-1">Booking Reference</h5>
                        <h1 class="display-6 fw-bold tracking-widest">#@Model.BookingID.ToString("D6")</h1>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-6">
                            <p class="text-muted mb-1 small text-uppercase">Passenger Name</p>
                            <h5 class="fw-bold mb-0">@(Model.User?.Name ?? "N/A")</h5>
                        </div>
                        <div class="col-6 text-end">
                            <p class="text-muted mb-1 small text-uppercase">Passport</p>
                            <h5 class="fw-bold mb-0">@(Model.User?.Passport_num ?? "N/A")</h5>
                        </div>
                    </div>

                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="row align-items-center">
                            <div class="col-8">
                                <p class="text-muted mb-1 small text-uppercase">Service Type</p>
                                <h4 class="mb-0">@(Model.Service?.ServiceType ?? "Unknown")</h4>
                            </div>
                            <div class="col-4 text-end">
                                <i class="fa-solid fa-plane-up fa-2x text-muted opacity-50"></i>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-6">
                            <p class="text-muted mb-1 small text-uppercase">Issue Date</p>
                            <p class="fw-bold mb-0">@Model.Date.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-6 text-end">
                            <p class="text-muted mb-1 small text-uppercase">Amount Paid</p>
                            <h4 class="text-success fw-bold mb-0">@(Model.Service?.BasePrice.ToString("C") ?? "$0.00")</h4>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 pb-4 text-center">
                    <div class="mt-2 text-center text-muted small border-top pt-3">
                        Present this digital ticket along with a valid passport upon arrival.
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>