@model IEnumerable<DAL.Models.Booking>

<h2>My Bookings</h2>

<table class="table">
    <thead>
        <tr>
            <th>Flight</th>
            <th>Date</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                @* <td>@item.Flight_Number</td> *@
                <td>@item.Date</td>
                <td>@item.Status</td>
                <td>
                    @if (item.Status != "Cancelled")
                    {
                        <a href="/Booking/Cancel?id=@item.BookingID&userId=@item.UserID">
                            Cancel
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>