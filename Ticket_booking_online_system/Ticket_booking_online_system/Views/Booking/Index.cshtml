@model IEnumerable<DAL.Models.Booking>
@{
    ViewData["Title"] = "All System Bookings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--dark-blue);"><i class="fa-solid fa-address-book me-2"></i>All System Bookings</h2>
    </div>

    <div class="card sky-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted">
                        <tr>
                            <th class="ps-4">Booking ID</th>
                            <th>Date Created</th>
                            <th>Status</th>
                            <th>Customer Email</th>
                            <th>Service Type</th>
                            <th class="text-end pe-4">Manage</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.BookingID.ToString("D5")</td>
                                <td>@item.Date.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    @if (item.Status == DAL.Models.BookingStatus.Confirmed)
                                    {
                                        <span class="badge bg-success">Confirmed</span>
                                    }
                                    else if (item.Status == DAL.Models.BookingStatus.Pending)
                                    {

                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>
                                <td class="text-muted">@item.User?.Email</td>
                                <td><span class="badge bg-secondary">@item.Service?.ServiceType</span></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.BookingID" class="btn btn-sm btn-outline-info">View</a>
                                        @if (User.Identity.IsAuthenticated && User.IsInRole("User"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.BookingID" class="btn btn-sm btn-outline-warning">Edit</a>
                                        }
                                        <form asp-action="Cancel" asp-route-id="@item.BookingID" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Cancel this booking?')">Cancel</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>