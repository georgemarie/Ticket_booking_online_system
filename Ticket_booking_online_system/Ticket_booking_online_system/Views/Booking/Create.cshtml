@model DAL.Models.Booking

@{
    ViewData["Title"] = "Secure Checkout";
}

<div class="container mt-2">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4" style="color: var(--dark-blue);">Secure Checkout</h2>
            
            <div class="card sky-card border-0 mb-4">
                <div class="card-header sky-header">
                    <h5 class="mb-0">Booking Summary</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">Passenger Name</div>
                        <div class="col-sm-8 fw-bold fs-5">@ViewBag.UserName</div>
                        
                        <div class="col-sm-4 text-muted mt-2">Email Address</div>
                        <div class="col-sm-8 mt-2">@ViewBag.UserEmail</div>

                        <div class="col-sm-4 text-muted mt-2">Passport Number</div>
                        <div class="col-sm-8 mt-2">@ViewBag.UserPassport</div>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <div class="row mt-4">
                        <div class="col-sm-4 text-muted">Service Type</div>
                        <div class="col-sm-8">
                            <span class="badge bg-secondary px-3 py-2">@ViewBag.ServiceType</span>
                        </div>

                        <div class="col-sm-4 text-muted mt-3">Booking Date</div>
                        <div class="col-sm-8 mt-3">@Model.Date.ToString("D")</div>
                        
                        <div class="col-sm-4 text-muted mt-3 fs-5">Total Price</div>
                        <div class="col-sm-8 mt-3 text-success fw-bold fs-4">@ViewBag.BasePrice.ToString("C")</div>
                    </div>
                </div>
                <div class="card-footer bg-light p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ServiceID" />
                        <input type="hidden" asp-for="Date" />
                        <input type="hidden" asp-for="Status" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-controller="Service" asp-action="Index" class="btn btn-link text-muted text-decoration-none">Cancel & Return</a>
                            <button type="submit" class="btn btn-sky btn-lg px-5">Confirm & Pay</button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="text-center text-muted small">
                <i class="fa-solid fa-lock me-1"></i> Your personal information is encrypted and securely processed.
            </div>
        </div>
    </div>
</div>