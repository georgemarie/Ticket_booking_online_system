@model DAL.Models.Review

<div class="card mt-4">
    <div class="card-header bg-dark text-white">
        <h3>Review Details</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Service</dt>
            <dd class="col-sm-9">@Model.Service?.ServiceType</dd>

            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.User?.Email</dd>

            <dt class="col-sm-3">Rating</dt>
            <dd class="col-sm-9">
                @for (int i = 0; i < Model.Rating; i++)
                {
                    <span class="text-warning">★</span>
                }
            </dd>

            <dt class="col-sm-3">Comment</dt>
            <dd class="col-sm-9">@Model.Comment</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.ReviewID" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>