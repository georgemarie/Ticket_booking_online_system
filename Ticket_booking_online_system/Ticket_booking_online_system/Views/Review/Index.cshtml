@model IEnumerable<DAL.Models.Review>

@{
    ViewData["Title"] = "Reviews";
}

<h1 class="mb-3">Reviews</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted">
        Total: <strong>@(Model?.Count() ?? 0)</strong> reviews
    </div>
    <a asp-action="Create" class="btn btn-primary">Create New Review</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No reviews found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Comment</th>
                    <th style="width:140px;">Rating</th>
                    <th>Service</th>
                    <th>Price</th>
                    <th>Location</th>
                    <th>User</th>
                    <th style="width:200px;" class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Comment))
                            {
                                @item.Comment
                            }
                            else
                            {
                                <span class="text-muted italic">No comment provided.</span>
                            }
                        </td>

                        <td>
                            @{
                                // Clamp rating between 0 and 5
                                var rating = item.Rating;
                                if (rating < 0) rating = 0;
                                if (rating > 5) rating = 5;
                            }

                            <div class="d-flex align-items-center">
                                <span class="badge bg-warning text-dark me-2">@rating</span>
                                <span class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= rating)
                                        {
                                            <span>★</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary opacity-50">★</span>
                                        }
                                    }
                                </span>
                            </div>
                        </td>

                        <td>
                            <span class="badge bg-info text-dark">
                                @(item.Service?.ServiceType ?? "N/A")
                            </span>
                        </td>

                        <td>
                            @if (item.Service != null)
                            {
                                <strong>@item.Service.BasePrice.ToString("C")</strong>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>

                        <td>
                            @(item.Service?.Location?.City ?? "N/A")
                        </td>

                        <td>
                            <small class="text-muted">@(item.User?.Email ?? "Anonymous")</small>
                        </td>

                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.ReviewID" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.ReviewID" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ReviewID" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}