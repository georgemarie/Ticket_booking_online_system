@model DAL.Models.Review

@{
    ViewData["Title"] = "Create Review";
}

<h1>Create Review</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="ServiceID" class="control-label">Service Type</label>
                <select asp-for="ServiceID" class="form-control" asp-items="ViewBag.Services">
                    <option value="">-- Select Service --</option>
                </select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="UserID" class="control-label">User Email</label>
                <select asp-for="UserID" class="form-control" asp-items="ViewBag.Users">
                    <option value="">-- Select User --</option>
                </select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label"></label>
                <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Comment" class="control-label"></label>
                <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>