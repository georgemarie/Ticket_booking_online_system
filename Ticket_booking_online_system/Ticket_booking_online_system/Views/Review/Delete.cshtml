@model DAL.Models.Review

<h2 class="text-danger">Are you sure you want to delete this?</h2>
<div class="alert alert-warning">
    <strong>Warning!</strong> This review by @Model.User?.Email will be permanently removed.
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Comment</dt>
        <dd class="col-sm-10">@Model.Comment</dd>
    </dl>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.ReviewID" method="post">
        <input type="hidden" asp-for="ReviewID" />
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>